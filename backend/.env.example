# ============================================================
# SOLDIER OF GOD — Backend env reference
# Copy to .env (or .env.local) and edit. Loaded by run.ps1.
# Real .env is gitignored; do NOT commit secrets.
# ============================================================

# ---- Operator gates ----
# Enables the L2-support write surface: IMSI override, budget edits,
# memory CRUD, and the cross-user patterns aggregate. Off in
# customer-facing deploys; on in the rain ops command-centre.
RAIN_SUPPORT_L2=true

# ---- Sales poller ----
# The Loop / rainOne CTEs use prod-only columns (e.g.
# product.product_order_item.product_offering_ref_id). Pointing the
# poller at SIT throws SQLSTATE 42703 immediately. Always target
# the prod connection — the poller is read-only.
SALES_POLLER_CONNECTION_ID=axiom-prod

# ---- Optional: alert email pipeline ----
# Set all four to enable the EmailSink so platform incidents
# trigger emails (with 30-min dedup). Empty = disabled.
# RAIN_ALERT_SMTP_HOST=smtp.rain.co.za
# RAIN_ALERT_SMTP_USER=alerts@rain.co.za
# RAIN_ALERT_SMTP_PASS=...
# RAIN_ALERT_SMTP_TO=baptista.manuel@rain.co.za

# ---- Optional: Anthropic API path for the agent ----
# Without this the dispatcher falls through to the Claude CLI path.
# ANTHROPIC_API_KEY=sk-ant-...

# ---- Optional: USAGE source override ----
# Default 'axiom' (Snowflake middleware). 'gaussdb' switches the
# usage-summary tool to the Huawei DWS.
# USAGE_SOURCE=axiom

# ---- Optional: Axiom HTTP API ----
# When set, /api/v1/axiom-api/* proxies hit the rain Axiom REST API
# (rate-limited). Without this the UI shows "configure base URL".
# AXIOM_API_BASE_URL=https://api.sit.rain.co.za
