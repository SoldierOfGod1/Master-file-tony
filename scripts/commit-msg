#!/usr/bin/env bash
# =============================================================================
# Commit-msg hook — SOLDIER OF GOD Command Centre
# Validates conventional commit message format
# =============================================================================

set -euo pipefail

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(head -1 "$COMMIT_MSG_FILE")

RED='\033[0;31m'
GREEN='\033[0;32m'
NC='\033[0m'

# Conventional commit pattern:
#   type(optional-scope): description
#
# Allowed types: feat, fix, refactor, docs, test, chore, perf, ci, build, style, revert
PATTERN='^(feat|fix|refactor|docs|test|chore|perf|ci|build|style|revert)(\([a-z0-9-]+\))?: .{3,}'

# Allow merge commits
MERGE_PATTERN='^Merge '

# Allow revert commits
REVERT_PATTERN='^Revert "'

if echo "$COMMIT_MSG" | grep -qE "$MERGE_PATTERN"; then
    exit 0
fi

if echo "$COMMIT_MSG" | grep -qE "$REVERT_PATTERN"; then
    exit 0
fi

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
    echo ""
    echo -e "${RED}Invalid commit message format.${NC}"
    echo ""
    echo "  Your message:  $COMMIT_MSG"
    echo ""
    echo "  Expected format: <type>(<scope>): <description>"
    echo ""
    echo "  Allowed types:"
    echo "    feat     — A new feature"
    echo "    fix      — A bug fix"
    echo "    refactor — Code refactoring (no feature or fix)"
    echo "    docs     — Documentation changes"
    echo "    test     — Adding or updating tests"
    echo "    chore    — Maintenance tasks"
    echo "    perf     — Performance improvements"
    echo "    ci       — CI/CD changes"
    echo "    build    — Build system or dependency changes"
    echo "    style    — Code style changes (formatting, etc.)"
    echo "    revert   — Reverting a previous commit"
    echo ""
    echo "  Examples:"
    echo "    feat: add user authentication endpoint"
    echo "    fix(api): resolve race condition in WebSocket handler"
    echo "    docs: update deployment instructions"
    echo "    chore(deps): bump Go version to 1.25"
    echo ""
    exit 1
fi

# Check description length (max 72 chars for first line)
MSG_LENGTH=${#COMMIT_MSG}
if [ "$MSG_LENGTH" -gt 72 ]; then
    echo ""
    echo -e "${RED}Commit message first line too long ($MSG_LENGTH > 72 chars).${NC}"
    echo "  Keep the first line under 72 characters."
    echo "  Use the commit body for additional details."
    echo ""
    exit 1
fi

echo -e "${GREEN}Commit message format OK.${NC}"
exit 0
